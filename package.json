{
  "name": "brevo-login-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Email OTP login demo built with Express, React, Vite, SQLite, and Brevo.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch-path=server/src --watch-path=.env server/src/app.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/src/app.js",
    "test:flow": "node scripts/test-login-flow.js"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "vite": "^6.3.5"
  }
}
